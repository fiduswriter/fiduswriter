#!/usr/bin/make -f

export DH_VERBOSE=1
export PYBUILD_NAME=fiduswriter
export DH_VIRTUALENV_INSTALL_ROOT=/opt
export DH_VIRTUALENV_INSTALL_SUFFIX=fiduswriter

# Python 3.14.5 configuration
PYTHON_VERSION=3.14.5
PYTHON_MAJORMINOR=3.14
PYTHON_URL=https://www.python.org/ftp/python/$(PYTHON_VERSION)/Python-$(PYTHON_VERSION).tar.xz
PYTHON_PREFIX=/opt/fiduswriter/python$(PYTHON_MAJORMINOR)
PYTHON_BIN=$(PYTHON_PREFIX)/bin/python$(PYTHON_MAJORMINOR)

# Prevent setuptools from downloading dependencies
export PYTHONDONTWRITEBYTECODE=1
export NO_COMPILEMESSAGES=true

# The Python binary has rpath=$(PYTHON_PREFIX)/lib (the final install location),
# but during the build the shared library lives at debian/fiduswriter-server$(PYTHON_PREFIX)/lib.
# Setting LD_LIBRARY_PATH here lets the dynamic linker find libpython3.14.so
# without a segfault when pip or any other Python command is invoked at build time.
PYTHON_BUILDLIB = $(CURDIR)/debian/fiduswriter-server$(PYTHON_PREFIX)/lib
PYTHON_EXEC = LD_LIBRARY_PATH=$(PYTHON_BUILDLIB):$$LD_LIBRARY_PATH $(CURDIR)/debian/fiduswriter-server$(PYTHON_BIN)

# Read optional plugin package-specs from pyproject.toml
# [project.optional-dependencies].  Lines look like:
#   books = ["fiduswriter-books ~= 4.1.4"]
# We extract the quoted spec and collapse the space around ~= so pip is happy.
PLUGIN_PKGS := $(shell grep '"fiduswriter-' pyproject.toml | \
	sed 's/.*"\(fiduswriter-[^"]*\)".*/\1/' | \
	tr -d ' ' | tr '\n' ' ')

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_configure:
	# Skip pybuild auto_configure - we build our own Python and don't need
	# the system Python to validate pyproject.toml during packaging
	@echo "Skipping pybuild auto_configure"

override_dh_auto_clean:
	# Skip pybuild auto_clean since we're building our own Python
	rm -rf build
	rm -rf *.egg-info
	rm -rf fiduswriter/.transpile
	rm -rf fiduswriter/static-transpile
	rm -rf fiduswriter/static-collected
	rm -rf fiduswriter/static-libs
	rm -rf fiduswriter/node_modules
	rm -rf debian/fiduswriter-server/
	rm -rf debian/fiduswriter-server-nodejs/
	rm -rf .pybuild
	rm -rf Python-$(PYTHON_VERSION)
	rm -f Python-$(PYTHON_VERSION).tar.xz
	find . -name "*.pyc" -delete
	find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true
	find . -name "*.mo" -delete 2>/dev/null || true

override_dh_auto_build:
	# Build phase - compile message catalogs with system Python's pybabel
	# (avoid setup.py to prevent setuptools from validating pyproject.toml)
	pybabel compile -d fiduswriter/locale -D django 2>/dev/null || true
	pybabel compile -d fiduswriter/locale -D djangojs 2>/dev/null || true

override_dh_auto_install:
	# Check if Python is already built and cached
	@if [ -d "$(CURDIR)/.python-build-cache/python$(PYTHON_MAJORMINOR)" ] && \
	    [ -f "$(CURDIR)/.python-build-cache/python$(PYTHON_MAJORMINOR)/bin/python$(PYTHON_MAJORMINOR)" ]; then \
		echo "Using cached Python $(PYTHON_VERSION)..."; \
		mkdir -p $(CURDIR)/debian/fiduswriter-server$(PYTHON_PREFIX); \
		cp -r $(CURDIR)/.python-build-cache/python$(PYTHON_MAJORMINOR)/* $(CURDIR)/debian/fiduswriter-server$(PYTHON_PREFIX)/; \
	else \
		echo "Downloading Python $(PYTHON_VERSION)..."; \
		wget -q $(PYTHON_URL) || curl -sLO $(PYTHON_URL); \
		tar -xf Python-$(PYTHON_VERSION).tar.xz; \
		echo "Building Python $(PYTHON_VERSION) (this will be cached)..."; \
		cd Python-$(PYTHON_VERSION) && \
			./configure \
				--prefix=$(CURDIR)/debian/fiduswriter-server$(PYTHON_PREFIX) \
				--enable-optimizations \
				--with-lto \
				--enable-shared \
				--with-system-ffi \
				--with-computed-gotos \
				--enable-loadable-sqlite-extensions \
				LDFLAGS="-Wl,-rpath=$(PYTHON_PREFIX)/lib" && \
			make -j$$(nproc) && \
			make install; \
		echo "Caching Python build for future use..."; \
		mkdir -p $(CURDIR)/.python-build-cache; \
		cp -r $(CURDIR)/debian/fiduswriter-server$(PYTHON_PREFIX) $(CURDIR)/.python-build-cache/python$(PYTHON_MAJORMINOR); \
		echo "Python build cached in .python-build-cache/"; \
	fi
	
	# Install setuptools, wheel, and babel in bundled Python
	$(PYTHON_EXEC) -m pip install --no-cache-dir setuptools wheel babel
	
	# Compile message catalogs with bundled Python (in case it failed earlier)
	$(PYTHON_EXEC) setup.py compile_catalog || true
	
	# Install directly into bundled Python (no venv needed)
	@echo "Installing packages into bundled Python..."
	$(PYTHON_EXEC) -m pip install --no-cache-dir \
		--upgrade pip setuptools wheel
	
	# Install all dependencies from requirements.txt
	@echo "Installing Python dependencies..."
	$(PYTHON_EXEC) -m pip install --no-cache-dir \
		-r fiduswriter/requirements.txt
	
	# Install nodejs-wheel to bundle Node.js in Python environment (required for transpile)
	# These files will be moved to a separate fiduswriter-server-nodejs package later.
	@echo "Installing Node.js via nodejs-wheel..."
	$(PYTHON_EXEC) -m pip install --no-cache-dir \
		nodejs-wheel
	
	# Install database adapters (PostgreSQL and MySQL)
	@echo "Installing database adapters..."
	$(PYTHON_EXEC) -m pip install --no-cache-dir \
		psycopg2-binary \
		mysqlclient
	
	# Install all optional dependencies (plugins - versions read from pyproject.toml)
	@echo "Installing optional plugin modules..."
	@echo "  Packages: $(PLUGIN_PKGS)"
	$(PYTHON_EXEC) -m pip install --no-cache-dir --upgrade $(PLUGIN_PKGS)
	
	# Install fiduswriter package itself
	$(PYTHON_EXEC) -m pip install --no-cache-dir \
		--no-deps .
	
	# Fix all shebang lines in bin directory (pip hardcodes build paths)
	@echo "Fixing shebang lines in all Python scripts..."
	find $(CURDIR)/debian/fiduswriter-server$(PYTHON_PREFIX)/bin -type f -exec \
		sed -i '1s|^#!.*python.*|#!/opt/fiduswriter/python$(PYTHON_MAJORMINOR)/bin/python$(PYTHON_MAJORMINOR)|' {} +
	
	# Create wrapper script
	install -d debian/fiduswriter-server/usr/bin
	echo '#!/bin/sh' > debian/fiduswriter-server/usr/bin/fiduswriter
	echo 'export PATH=$(PYTHON_PREFIX)/bin:/usr/local/bin:/usr/bin:/bin' >> debian/fiduswriter-server/usr/bin/fiduswriter
	echo 'export LD_LIBRARY_PATH=$(PYTHON_PREFIX)/lib:$$LD_LIBRARY_PATH' >> debian/fiduswriter-server/usr/bin/fiduswriter
	echo 'export PROJECT_PATH=/var/lib/fiduswriter' >> debian/fiduswriter-server/usr/bin/fiduswriter
	echo 'export SRC_PATH=$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages/fiduswriter' >> debian/fiduswriter-server/usr/bin/fiduswriter
	echo 'cd /var/lib/fiduswriter' >> debian/fiduswriter-server/usr/bin/fiduswriter
	echo 'exec $(PYTHON_PREFIX)/bin/python$(PYTHON_MAJORMINOR) -m fiduswriter.manage --pythonpath /etc/fiduswriter "$$@"' >> debian/fiduswriter-server/usr/bin/fiduswriter
	chmod +x debian/fiduswriter-server/usr/bin/fiduswriter
	
	# Install configuration template
	install -D -m 644 fiduswriter/configuration-default.py \
		debian/fiduswriter-server/etc/fiduswriter/configuration.py.template
	
	# Install requirements.txt for reference
	install -D -m 644 fiduswriter/requirements.txt \
		debian/fiduswriter-server/usr/share/fiduswriter/requirements.txt
	
	# Create necessary directories
	install -d debian/fiduswriter-server/var/lib/fiduswriter
	install -d debian/fiduswriter-server/var/lib/fiduswriter/media
	install -d debian/fiduswriter-server/var/log/fiduswriter
	install -d debian/fiduswriter-server/usr/share/fiduswriter
	
	# Install systemd service file (with Python version substitution)
	install -d debian/fiduswriter-server/usr/lib/systemd/system
	sed 's|python3\.14|python$(PYTHON_MAJORMINOR)|g' debian/fiduswriter.service > \
		debian/fiduswriter-server/usr/lib/systemd/system/fiduswriter.service
	chmod 644 debian/fiduswriter-server/usr/lib/systemd/system/fiduswriter.service
	
	# Remove Python test suites and development files not needed at runtime
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/test
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/lib2to3
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/ensurepip
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/idlelib
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/tkinter
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/turtledemo
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/distutils/tests
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/unittest/test
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/include
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/share/man
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/share/doc
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/pkgconfig
	# Remove test directories from pip-installed packages
	find debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages -type d -name test -exec rm -rf {} + 2>/dev/null || true
	find debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages -type d -name tests -exec rm -rf {} + 2>/dev/null || true
	# Remove cached/compiled files
	find debian/fiduswriter-server$(PYTHON_PREFIX) -name '*.pyc' -delete 2>/dev/null || true
	find debian/fiduswriter-server$(PYTHON_PREFIX) -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null || true
	# Strip shared libraries more aggressively
	find debian/fiduswriter-server$(PYTHON_PREFIX) -type f -name '*.so' -exec strip --strip-unneeded {} + 2>/dev/null || true
	
	# Remove Python config dir (static lib + headers only needed for building extensions)
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/config-$(PYTHON_MAJORMINOR)-x86_64-linux-gnu
	
	# Remove Python internal test extension modules
	find debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/lib-dynload -name '_test*.so' -delete
	
	# Remove pycryptodome self-test data
	rm -rf debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages/Crypto/SelfTest
	
	# Remove pydoc_data topics
	rm -f debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/pydoc_data/topics.py
	
	# Remove autobahn flatc binary (not needed at runtime)
	rm -f debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages/autobahn/_flatc/bin/flatc
	
	# Move nodejs-wheel files to separate package
	mkdir -p debian/fiduswriter-server-nodejs$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages
	mkdir -p debian/fiduswriter-server-nodejs$(PYTHON_PREFIX)/bin
	
	# Move all nodejs_wheel* site-packages directories to the nodejs package
	for d in debian/fiduswriter-server$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages/nodejs_wheel*; do \
		[ -e "$$d" ] && mv "$$d" \
		   debian/fiduswriter-server-nodejs$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages/; \
	done
	
	# Move nodejs wrapper scripts from bin/
	for script in node npm npx corepack; do \
		if [ -f debian/fiduswriter-server$(PYTHON_PREFIX)/bin/$$script ]; then \
			mv debian/fiduswriter-server$(PYTHON_PREFIX)/bin/$$script \
			   debian/fiduswriter-server-nodejs$(PYTHON_PREFIX)/bin/; \
		fi; \
	done
	
	# Remove unnecessary C++ headers from bundled nodejs (65MB+, not needed at runtime)
	rm -rf debian/fiduswriter-server-nodejs$(PYTHON_PREFIX)/lib/python$(PYTHON_MAJORMINOR)/site-packages/nodejs_wheel/include

override_dh_fixperms:
	dh_fixperms
	# Ensure proper permissions for runtime directories
	chmod 750 debian/fiduswriter-server/var/lib/fiduswriter || true
	chmod 750 debian/fiduswriter-server/var/log/fiduswriter || true
	# Fix virtualenv and Python permissions
	chmod 755 debian/fiduswriter-server/opt/fiduswriter/venv/bin/* || true
	chmod 755 debian/fiduswriter-server$(PYTHON_PREFIX)/bin/* || true
	chmod 755 debian/fiduswriter-server-nodejs$(PYTHON_PREFIX)/bin/* || true

override_dh_installinit:
	dh_installinit --name=fiduswriter --no-start

override_dh_installsystemd:
	dh_installsystemd --name=fiduswriter --no-start

# Skip dh_strip - we already strip bundled .so files manually, and
# dh_strip's objcopy --only-keep-debug fails on pre-stripped libraries.
override_dh_strip:
	@echo "Skipping dh_strip - bundled libraries already stripped"

# Don't compress files in virtualenv
override_dh_compress:
	dh_compress -X.py -X.txt -X.so

# Use xz compression for smaller .deb packages
override_dh_builddeb:
	dh_builddeb -- -Zxz -z9

# Skip dwz for bundled Python - many bundled .so files have debug
# sections that dwz cannot handle
override_dh_dwz:
	@echo "Skipping dh_dwz for bundled Python binaries"

# Skip shlibs processing for bundled libraries
override_dh_shlibdeps:
	dh_shlibdeps -X/opt/fiduswriter/
