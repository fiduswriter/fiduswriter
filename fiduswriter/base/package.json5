// Fidus Writer will combine this file with package.json files in other installed
// apps before executing npm commands. Different from a regular package.json, comments
// are allowed in this file.

{
    name: "fidus-writer",
    description: "Install dependencies for ES6 transpilation",
    scripts: {
        copy_fwtoolkit_css: "mkdir -p ../static-libs/css/fwtoolkit/ && rsync -av --no-perms --checksum node_modules/fwtoolkit/css/ ../static-libs/css/fwtoolkit/",
        copy_frontend_css: "mkdir -p ../static-libs/css/ && rsync -av --no-perms --checksum node_modules/@fiduswriter/frontend/css/ ../static-libs/css/",
        copy_editor_css: "mkdir -p ../static-libs/css/editor/ && (rsync -av --no-perms --checksum node_modules/@fiduswriter/editor/css/ ../static-libs/css/editor/ 2>/dev/null || echo 'Editor CSS not found, skipping.')",
        copy_bibliography_css: "mkdir -p ../static-libs/css/bibliography/ && (rsync -av --no-perms --checksum node_modules/@fiduswriter/bibliography-manager/css/ ../static-libs/css/bibliography/ 2>/dev/null || echo 'Bibliography CSS not found, skipping.')",
        copy_frontend_static: "mkdir -p ../static-libs/ && rsync -av --no-perms --checksum node_modules/@fiduswriter/frontend/static/ ../static-libs/",
        copy_fontawesome: "mkdir -p ../static-libs/css/fontawesome/css/ && rsync -av --no-perms --checksum node_modules/@fortawesome/fontawesome-free/css/ ../static-libs/css/fontawesome/css/ && rsync -av --no-perms --checksum node_modules/@fortawesome/fontawesome-free/webfonts/ ../static-libs/css/fontawesome/webfonts/",
        copy_prosemirror_css: "mkdir -p ../static-libs/css/ && rsync -av --no-perms --checksum node_modules/prosemirror-view/style/prosemirror.css ../static-libs/css/ && rsync -av --no-perms --checksum node_modules/prosemirror-menu/style/menu.css ../static-libs/css/prosemirror-menu.css && rsync -av --no-perms --checksum node_modules/prosemirror-example-setup/style/style.css ../static-libs/css/prosemirror-example-setup.css",
        copy_mathlive: "mkdir -p ../static-libs/css/libs/ ../static-libs/zip/ && (rsync -av --no-perms --checksum node_modules/@fiduswriter/document/static-libs/css/libs/mathlive/ ../static-libs/css/libs/mathlive/ 2>/dev/null || echo 'MathLive CSS not found (transitive dep not hoisted), skipping.') && (rsync -av --no-perms --checksum node_modules/@fiduswriter/document/static-libs/zip/mathlive_style.zip ../static-libs/zip/mathlive_style.zip 2>/dev/null || echo 'MathLive zip not found, skipping.')",
        copy_schema: "mkdir -p ../static-libs/json && (test -f node_modules/@fiduswriter/document/schema.json && cp node_modules/@fiduswriter/document/schema.json ../static-libs/json/schema.json) || (node node_modules/@fiduswriter/document/scripts/export-schema.js 2>/dev/null && cp node_modules/@fiduswriter/document/schema.json ../static-libs/json/schema.json) || echo 'Schema not found (transitive dep not hoisted), skipping.'",
        postinstall: "npm run copy_fwtoolkit_css && npm run copy_frontend_css && npm run copy_editor_css && npm run copy_bibliography_css && npm run copy_frontend_static && npm run copy_fontawesome && npm run copy_prosemirror_css && npm run copy_mathlive && npm run copy_schema",
        "babel-transform-template-literals": "babel --plugins @babel/plugin-transform-template-literals"
    },
    author: "Johannes Wilm",
    license: "AGPL",
    private: true,
    dependencies: {
        "@fiduswriter/frontend": "file:../../../fiduswriter-frontend-js",
        "@fiduswriter/editor": "file:../../../fiduswriter-editor-js",
        "@fiduswriter/bibliography-manager": "file:../../../fiduswriter-bibliography-manager-js",
        "@fiduswriter/document-template-editor": "file:../../../fiduswriter-document-template-editor-js",
        "fwtoolkit": "file:../../../fwtoolkit",
        "@fortawesome/fontawesome-free": "^7.2.0",
        "source-map-loader": "5.0.0",
        "regenerator-runtime": "0.14.1",
        "@aaroon/workbox-rspack-plugin": "0.3.3"
    }
}
