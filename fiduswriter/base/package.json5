// Fidus Writer will combine this file with package.json files in other installed
// apps before executing npm commands. Different from a regular package.json, comments
// are allowed in this file.

{
    name: "fidus-writer",
    description: "Install dependencies for ES6 transpilation",
    scripts: {
        copy_fontawesome: "mkdir -p ../static-libs/css/fontawesome/css/ && rsync -av --no-perms --checksum node_modules/@fortawesome/fontawesome-free/css/ ../static-libs/css/fontawesome/css/ && rsync -av --no-perms --checksum node_modules/@fortawesome/fontawesome-free/webfonts/ ../static-libs/css/fontawesome/webfonts/",
        copy_prosemirror_css: "mkdir -p ../static-libs/css/ && rsync -av --no-perms --checksum node_modules/prosemirror-view/style/prosemirror.css ../static-libs/css/ && rsync -av --no-perms --checksum node_modules/prosemirror-menu/style/menu.css ../static-libs/css/prosemirror-menu.css && rsync -av --no-perms --checksum node_modules/prosemirror-example-setup/style/style.css ../static-libs/css/prosemirror-example-setup.css",
        copy_mathlive: "mkdir -p ../static-libs/css/libs/ ../static-libs/zip/ && rsync -av --no-perms --checksum node_modules/@fiduswriter/document/static-libs/css/libs/mathlive/ ../static-libs/css/libs/mathlive/ && rsync -av --no-perms --checksum node_modules/@fiduswriter/document/static-libs/zip/mathlive_style.zip ../static-libs/zip/mathlive_style.zip",
        copy_schema: "mkdir -p ../static-libs/json && (test -f node_modules/@fiduswriter/document/schema.json && cp node_modules/@fiduswriter/document/schema.json ../static-libs/json/schema.json) || (node node_modules/@fiduswriter/document/scripts/export-schema.js && cp node_modules/@fiduswriter/document/schema.json ../static-libs/json/schema.json)",
        copy_fwtoolkit_css: "mkdir -p ../static-libs/css/ && rsync -av --no-perms --checksum --exclude=forms.css --exclude=colors.css node_modules/fwtoolkit/css/ ../static-libs/css/",
        postinstall: "npm run copy_fontawesome && npm run copy_prosemirror_css && npm run copy_mathlive && npm run copy_schema && npm run copy_fwtoolkit_css",
        "babel-transform-template-literals": "babel --plugins @babel/plugin-transform-template-literals"
    },
    author: "Johannes Wilm",
    license: "AGPL",
    private: true,
    dependencies: {
        "@fiduswriter/frontend": "^0.1.18",
        "@fiduswriter/image-manager": "^0.1.12",
        "fwtoolkit": "^0.1.11",
        "file-loader": "^6.2.0",
        "diff-dom": "5.2.1",
        "downloadjs": "1.4.7",
        "@fortawesome/fontawesome-free": "^7.2.0",
        "simple-datatables": "^10.2.0",
        "@vivliostyle/print": "^2.42.0",
        "w3c-keyname": "2.2.8",
        "source-map-loader": "5.0.0",
        "stacktrace-js": "2.0.2",
        "regenerator-runtime": "0.14.1",
        "@aaroon/workbox-rspack-plugin": "0.3.3",
        "qrcode": "^1.5.4"
    },
    overrides: {
        "prosemirror-changeset": "2.2.1",
        "prosemirror-collab": "1.3.1",
        "prosemirror-commands": "1.7.0",
        "prosemirror-dropcursor": "1.8.1",
        "prosemirror-example-setup": "1.2.3",
        "prosemirror-gapcursor": "1.3.2",
        "prosemirror-history": "1.3.2",
        "prosemirror-keymap": "1.2.2",
        "prosemirror-menu": "1.2.4",
        "prosemirror-model": "1.25.0",
        "prosemirror-schema-basic": "1.2.4",
        "prosemirror-schema-list": "1.5.1",
        "prosemirror-state": "1.4.3",
        "prosemirror-tables": "1.6.4",
        "prosemirror-transform": "1.10.3",
        "prosemirror-view": "1.38.1",
        "prosemirror-suggestions": "0.2.0"
    }
}
