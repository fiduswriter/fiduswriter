#: document/emails.py:21
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has changed your access rights to %(rights)s on the document '%(document_title)s'. \n"
"Open the document: %(link)s"
msgstr ""
"Здравей, %(collaborator_name)s,\n"
"%(owner)s промени вашите права за достъп на %(rights)s върху документа „%(document_title)s“. \n"
"Отворете документа: %(link)s"

#: document/emails.py:32
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has changed your access rights to"
" %(rights)s on the document '%(document_title)s'.</p>"
msgstr ""
"<p>Здравейте, %(collaborator_name)s,<br>%(owner)s промени вашите права за "
"достъп на %(rights)s до документа „%(document_title)s“.</p>"

#: document/emails.py:43
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has shared the document '%(document_title)s' with you and given you %(rights)s access rights. \n"
"Open document: %(link)s"
msgstr ""
"Здравей, %(collaborator_name)s,\n"
"%(owner)s сподели документа „%(document_title)s“ с вас и ви даде права за достъп %(rights)s. \n"
"Отворете документ: %(link)s"

#: document/emails.py:55
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has shared the document "
"'%(document_title)s' with you and given you %(rights)s access rights.</p>"
msgstr ""
"<p>Здравейте, %(collaborator_name)s,<br>%(owner)s сподели документа "
"„%(document_title)s“ с вас и ви даде %(rights)s права за достъп.</p>"

