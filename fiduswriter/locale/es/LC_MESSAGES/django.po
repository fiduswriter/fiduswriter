msgid "Untitled"
msgstr "Sin título"

#: document/emails.py:21
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has changed your access rights to %(rights)s on the document '%(document_title)s'. \n"
"Open the document: %(link)s"
msgstr ""
"Hola %(collaborator_name)s,\n"
"%(owner)s ha cambiado sus derechos de acceso a %(rights)s en el documento '%(document_title)s'. \n"
"Abrir el documento: %(link)s"

#: document/emails.py:32
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has changed your access rights to"
" %(rights)s on the document '%(document_title)s'.</p>"
msgstr ""
"<p>Hola, %(collaborator_name)s,<br>%(owner)s ha cambiado tus derechos de "
"acceso a %(rights)s en el documento '%(document_title)s'.</p>"

#: document/emails.py:43
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has shared the document '%(document_title)s' with you and given you %(rights)s access rights. \n"
"Open document: %(link)s"
msgstr ""
"Hola %(collaborator_name)s,\n"
"%(owner)s ha compartido el documento '%(document_title)s' contigo y te ha otorgado %(rights)s derechos de acceso. \n"
"Abrir documento: %(link)s"

#: document/emails.py:55
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has shared the document "
"'%(document_title)s' with you and given you %(rights)s access rights.</p>"
msgstr ""
"<p>Hola, %(collaborator_name)s,<br>%(owner)s ha compartido el documento "
"'%(document_title)s' contigo y te ha otorgado %(rights)s derechos de "
"acceso.</p>"

#: document/emails.py:89
msgid "shared"
msgstr "compartido"

#: document/emails.py:91 document/emails.py:207 document/emails.py:286
msgid "Document"
msgstr "Documento"

