"Hey %(collaborator_name)s,\n"
"%(commentator)s has mentioned you in a comment in the document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Go to the document here: %(link)s"
msgstr ""
"Hola %(collaborator_name)s,\n"
"%(commentator)s te ha mencionado en un comentario en el documento '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Ir al documento aquí: %(link)s"

#: document/emails.py:136
#, python-format
msgid ""
"Hey %(collaborator_name)s,<br>%(commentator)s has mentioned you in a comment"
" in the document '%(document_title)s'."
msgstr ""
"Hola, %(collaborator_name)s,<br>%(commentator)s te ha mencionado en un "
"comentario en el documento '%(document_title)s'."

