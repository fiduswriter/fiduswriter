msgstr ""
"Hola %(owner_name)s,\n"
"%(requester_name)s ha solicitado a %(rights)s acceso al documento '%(document_title)s'. \n"
"Abra el documento para otorgar acceso: %(link)s"

#: document/emails.py:251
#, python-format
msgid ""
"<p>Hey %(owner_name)s,<br>%(requester_name)s has requested %(rights)s access"
