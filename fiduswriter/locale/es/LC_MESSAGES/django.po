msgstr "Navegador no compatible"

#: browser_check/templates/browser_check/browser_not_supported.html:28
msgid ""
"\n"
"                Your browser is not supported by Fidus Writer.\n"
"                Please update! We recommend using a current\n"
"                version of Chrome/Chromium or Firefox on a\n"
"                desktop computer.\n"
"            "
msgstr ""
"\n"
"                Su navegador no es compatible con Fidus Writer.\n"
"               ¡Por favor actualice! Recomendamos usar una versión\n"
"                actual de Chrome/Chromium o de Firefox en una computadora.\n"
"                "

