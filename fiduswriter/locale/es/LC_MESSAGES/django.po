msgstr ""
"<p>Hola, %(collaborator_name)s,<br>%(commentator)s te ha asignado un "
"comentario en el documento '%(document)s':</p>%(comment_html)s<p>Ve al "
"documento <a href=\"%(link)s\">aquí</a>.</p>"

