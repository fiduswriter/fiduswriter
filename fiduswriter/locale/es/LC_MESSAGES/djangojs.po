#: document/static/js/modules/documents/overview/index.js:872
#: document/static/js/modules/documents/overview/index.js:887
msgid "Disadvantages"
msgstr "Desventajas"

#: document/static/js/modules/documents/overview/index.js:874
msgid "Limited access rights options (no tracked changes or review modes)."
msgstr ""
"Opciones de derechos de acceso limitados (sin seguimiento de cambios ni "
"modos de revisión)."

#: document/static/js/modules/documents/overview/index.js:875
msgid ""
"If you lose the password or passphrase, there is no way to recover the "
"document."
msgstr ""
"Si pierde la contraseña o la frase de contraseña, no hay forma de recuperar "
"el documento."

#: document/static/js/modules/documents/overview/index.js:876
msgid ""
"You must share the password with collaborators manually (unless they use a "
"personal passphrase)."
msgstr ""
"Debes compartir la contraseña con los colaboradores manualmente (a menos que"
" utilicen una frase de contraseña personal)."

#: document/static/js/modules/documents/overview/index.js:880
msgid "Regular documents are the default and work well for most users."
msgstr ""
"Los documentos normales son los predeterminados y funcionan bien para la "
"mayoría de los usuarios."

#: document/static/js/modules/documents/overview/index.js:883
msgid "Full access rights options including tracked changes and review modes."
msgstr ""
"Opciones de derechos de acceso completo, incluidos cambios rastreados y "
"modos de revisión."

#: document/static/js/modules/documents/overview/index.js:884
msgid "No risk of losing access if you forget a password."
msgstr "No hay riesgo de perder el acceso si olvida una contraseña."

#: document/static/js/modules/documents/overview/index.js:885
msgid "Easier collaboration — no need to share passwords with collaborators."
msgstr ""
"Colaboración más sencilla: no es necesario compartir contraseñas con los "
"colaboradores."

#: document/static/js/modules/documents/overview/index.js:889
msgid "The server can technically access the document contents."
msgstr "Técnicamente, el servidor puede acceder al contenido del documento."

#: document/static/js/modules/documents/overview/index.js:890
msgid "No additional protection beyond your account password."
msgstr "No hay protección adicional más allá de la contraseña de su cuenta."

#: document/static/js/modules/documents/overview/index.js:894
