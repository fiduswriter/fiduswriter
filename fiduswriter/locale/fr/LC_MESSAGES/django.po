msgstr "Navigateur non pris en charge"

#: browser_check/templates/browser_check/browser_not_supported.html:28
msgid ""
"\n"
"                Your browser is not supported by Fidus Writer.\n"
"                Please update! We recommend using a current\n"
"                version of Chrome/Chromium or Firefox on a\n"
"                desktop computer.\n"
"            "
msgstr ""
"\n"
"                Votre navigateur n'est pas pris en charge par Fidus Writer.\n"
"                Veuillez mettre à jour! Nous vous recommandons d'utiliser "
"une version à jour  courant de Chrome / Chromium ou Firefox sur un\n"
"                ordinateur de bureau.\n"
"                        "

