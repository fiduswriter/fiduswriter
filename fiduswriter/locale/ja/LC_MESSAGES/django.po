"%(collaborator_name)s さん、\n"
"%(owner)s はドキュメント '%(document_title)s' をあなたと共有し、%(rights)s のアクセス権を与えました。 \n"
"開いているドキュメント: %(link)s"

#: document/emails.py:55
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has shared the document "
"'%(document_title)s' with you and given you %(rights)s access rights.</p>"
msgstr ""
"<p>%(collaborator_name)s さん、<br>%(owner)s がドキュメント '%(document_title)s' "
"をあなたと共有し、%(rights)s のアクセス権を与えました。</p>"

