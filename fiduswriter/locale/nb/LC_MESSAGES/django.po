msgstr "Legg til %(name)s"

#: document/templates/admin/document/document/change_list_object_tools.html:13
#: document/templates/admin/document/maintenance.html:4
msgid "Maintenance"
msgstr "Vedlikehold"

#: document/templates/admin/document/maintenance.html:19
msgid ""
"\n"
"            Before and after upgrading Fidus Writer, you should update all the documents\n"
"            of all users to the newest document version. Only do this if you know that\n"
"            no user is currently editing any document!\n"
"            "
msgstr ""
"\n"
"Før og etter oppgradering av Fidus Writer bør du oppdatere alle dokumentene\n"
"            av alle brukere til den nyeste dokumentversjonen. Gjør dette bare hvis du vet det\n"
"            ingen bruker redigerer noe dokument for øyeblikket!"

#: document/templates/admin/document/maintenance.html:27
msgid "Update all documents (DANGER!)"
msgstr "Oppdater alle dokumenter (FARE!)"

#: style/models.py:74
msgid "Default"
msgstr "Misligholde"

#: style/views.py:27
msgid "The template needs at least 1 document style"
msgstr "Malen trenger minst én dokumentstil"

