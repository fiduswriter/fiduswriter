msgstr "Registrer deg/logg inn og godta/avslå invitasjonen"

#: user/emails.py:40
msgid "Fidus Writer contact invite"
msgstr "Fidus Writer kontaktinvitasjon"

#: user/emails.py:53
#, python-format
msgid ""
"Hey %(recipient_name)s, %(sender_name)s has declined your invite to connect on Fidus Writer. \n"
"See your list of contacts here: %(link)s"
msgstr ""
"Hei %(recipient_name)s, %(sender_name)s har avslått invitasjonen din til å koble til på Fidus Writer. \n"
"Se listen over kontakter her: %(link)s"

#: user/emails.py:62
#, python-format
msgid ""
"<p>Hey %(recipient_name)s,<br> %(sender_name)s has declined your invite to "
"connect on Fidus Writer.</p>"
