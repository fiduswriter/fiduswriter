msgid "Untitled"
msgstr "Uten tittel"

#: document/emails.py:21
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has changed your access rights to %(rights)s on the document '%(document_title)s'. \n"
"Open the document: %(link)s"
msgstr ""
"Hei %(collaborator_name)s,\n"
"%(owner)s har endret tilgangsrettighetene dine til %(rights)s på dokumentet '%(document_title)s'. \n"
"Åpne dokumentet: %(link)s"

#: document/emails.py:32
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has changed your access rights to"
" %(rights)s on the document '%(document_title)s'.</p>"
msgstr ""
"<p>Hei %(collaborator_name)s,<br>%(owner)s har endret tilgangsrettighetene "
"dine til %(rights)s på dokumentet '%(document_title)s'.</p>"

#: document/emails.py:43
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has shared the document '%(document_title)s' with you and given you %(rights)s access rights. \n"
"Open document: %(link)s"
msgstr ""
"Hei %(collaborator_name)s,\n"
"%(owner)s har delt dokumentet '%(document_title)s' med deg og gitt deg %(rights)s tilgangsrettigheter. \n"
"Åpne dokument: %(link)s"

#: document/emails.py:55
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has shared the document "
"'%(document_title)s' with you and given you %(rights)s access rights.</p>"
msgstr ""
"<p>Hei %(collaborator_name)s,<br>%(owner)s har delt dokumentet "
"'%(document_title)s' med deg og gitt deg %(rights)s tilgangsrettigheter.</p>"

#: document/emails.py:89
msgid "shared"
msgstr "delt"

#: document/emails.py:91 document/emails.py:207 document/emails.py:286
msgid "Document"
msgstr "Dokument"

#: document/emails.py:93 document/emails.py:209
msgid "Author"
msgstr "Forfatter"

#: document/emails.py:95
msgid "Access Rights"
msgstr "Tilgangsrettigheter"

#: document/emails.py:98 document/emails.py:214
msgid "Access the document"
msgstr "Få tilgang til dokumentet"

#: document/emails.py:101
#, python-format
msgid "Document shared: %(document_title)s"
msgstr "Dokument delt: %(document_title)s"

#: document/emails.py:123
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(commentator)s has mentioned you in a comment in the document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Go to the document here: %(link)s"
msgstr ""
"Hei %(collaborator_name)s,\n"
"%(commentator)s har nevnt deg i en kommentar i dokumentet '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Gå til dokumentet her: %(link)s"

#: document/emails.py:136
#, python-format
msgid ""
"Hey %(collaborator_name)s,<br>%(commentator)s has mentioned you in a comment"
" in the document '%(document_title)s'."
msgstr ""
"Hei %(collaborator_name)s,<br>%(commentator)s har nevnt deg i en kommentar i"
" dokumentet '%(document_title)s'."

#: document/emails.py:143
#, python-format
msgid "Comment on : %(document_title)s"
msgstr "Kommentar til : %(document_title)s"

#: document/emails.py:148
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(commentator)s has assigned you to a comment in the document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Go to the document here: %(link)s"
msgstr ""
"Hei %(collaborator_name)s,\n"
"%(commentator)s har tildelt deg en kommentar i dokumentet '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Gå til dokumentet her: %(link)s"

#: document/emails.py:159
#, python-format
msgid ""
"Hey %(collaborator_name)s,<br>%(commentator)s has assigned you to a comment "
"in the document '%(document_title)s'."
msgstr ""
"Hei %(collaborator_name)s,<br>%(commentator)s har tildelt deg en kommentar i"
" dokumentet '%(document_title)s'."

#: document/emails.py:166
#, python-format
msgid "Comment assignment on : %(document_title)s"
msgstr "Kommentaroppgave på : %(document_title)s"

#: document/emails.py:171
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(commentator)s has assigned you to a "
"comment in the document '%(document)s':</p>%(comment_html)s<p>Go to the "
"document <a href=\"%(link)s\">here</a>.</p>"
msgstr ""
"<p>Hei %(collaborator_name)s,<br>%(commentator)s har tildelt deg en "
"kommentar i dokumentet '%(document)s':</p>%(comment_html)s<p>Gå til "
"dokumentet <a href=\"%(link)s\">her</a>.</p>"

#: document/emails.py:211
msgid "Comment"
msgstr "Kommentar"

#: document/emails.py:239
#, python-format
msgid ""
"Hey %(owner_name)s,\n"
"%(requester_name)s has requested %(rights)s access to the document '%(document_title)s'. \n"
"Open the document to grant access: %(link)s"
msgstr ""
"Hei %(owner_name)s,\n"
"%(requester_name)s har bedt om %(rights)s tilgang til dokumentet '%(document_title)s'. \n"
"Åpne dokumentet for å gi tilgang: %(link)s"

#: document/emails.py:251
#, python-format
msgid ""
"<p>Hey %(owner_name)s,<br>%(requester_name)s has requested %(rights)s access"
" to the document '%(document_title)s'.</p>"
msgstr ""
"<p>Hei %(owner_name)s,<br>%(requester_name)s har bedt om %(rights)s tilgang "
"til dokumentet '%(document_title)s'.</p>"

#: document/emails.py:284
msgid "access request"
msgstr "tilgangsforespørsel"

#: document/emails.py:288
msgid "Requested by"
msgstr "Forespurt av"

#: document/emails.py:290
msgid "Requested rights"
msgstr "Forespurte rettigheter"

#: document/emails.py:293
msgid "Grant access"
msgstr "Gi tilgang"

#: document/emails.py:297
#, python-format
msgid "Access request: %(document_title)s"
msgstr "Tilgangsforespørsel: %(document_title)s"

