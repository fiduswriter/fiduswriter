msgid "Connections"
msgstr "Tilkoblinger"

#: user/emails.py:10
#, python-format
msgid ""
"Hey %(email)s,%(sender)s has invited you to connect on Fidus Writer. \n"
"Accept or reject the invite through this link: %(link)s"
msgstr ""
"Hei %(email)s,%(sender)s har invitert deg til å koble til på Fidus Writer. \n"
"Godta eller avslå invitasjonen via denne lenken: %(link)s"

#: user/emails.py:19
#, python-format
msgid ""
"<p>Hey %(email)s,<br> %(sender)s has invited you to connect on Fidus "
"Writer.</p>"
msgstr ""
"<p>Hei %(email)s,<br> %(sender)s har invitert deg til å koble til på Fidus "
"Writer.</p>"

#: user/emails.py:34
msgid "Invite for Fidus Writer"
msgstr "Inviter til Fidus Writer"

#: user/emails.py:37
