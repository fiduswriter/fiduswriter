#: user/emails.py:79 user/emails.py:121
msgid "See your list of contacts"
msgstr "Se listen over kontakter"

#: user/emails.py:82
msgid "Fidus Writer invite declined"
msgstr "Fidus Writer-invitasjon ble avslått"

#: user/emails.py:95
#, python-format
