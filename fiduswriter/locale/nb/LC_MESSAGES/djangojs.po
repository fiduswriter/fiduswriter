#: document/static/js/modules/documents/overview/index.js:867
#: document/static/js/modules/documents/overview/index.js:881
msgid "Advantages"
msgstr "Fordeler"

#: document/static/js/modules/documents/overview/index.js:869
msgid "Only people with the password can read the document."
msgstr "Bare personer med passord kan lese dokumentet."

#: document/static/js/modules/documents/overview/index.js:870
msgid "The server cannot access the document contents."
msgstr "Serveren kan ikke få tilgang til dokumentinnholdet."

#: document/static/js/modules/documents/overview/index.js:872
#: document/static/js/modules/documents/overview/index.js:887
msgid "Disadvantages"
msgstr "Ulemper"

#: document/static/js/modules/documents/overview/index.js:874
msgid "Limited access rights options (no tracked changes or review modes)."
msgstr ""
"Alternativer for begrensede tilgangsrettigheter (ingen sporede endringer "
"eller gjennomgangsmoduser)."

#: document/static/js/modules/documents/overview/index.js:875
msgid ""
"If you lose the password or passphrase, there is no way to recover the "
"document."
msgstr ""
"Hvis du mister passordet eller passordfrasen, er det ingen måte å "
"gjenopprette dokumentet på."

#: document/static/js/modules/documents/overview/index.js:876
msgid ""
"You must share the password with collaborators manually (unless they use a "
"personal passphrase)."
msgstr ""
"Du må dele passordet med samarbeidspartnere manuelt (med mindre de bruker en"
" personlig passordfrase)."

#: document/static/js/modules/documents/overview/index.js:880
msgid "Regular documents are the default and work well for most users."
msgstr "Vanlige dokumenter er standard og fungerer bra for de fleste brukere."

#: document/static/js/modules/documents/overview/index.js:883
msgid "Full access rights options including tracked changes and review modes."
msgstr ""
"Alternativer for fulle tilgangsrettigheter, inkludert sporede endringer og "
"gjennomgangsmoduser."

#: document/static/js/modules/documents/overview/index.js:884
msgid "No risk of losing access if you forget a password."
msgstr "Ingen risiko for å miste tilgang hvis du glemmer et passord."

#: document/static/js/modules/documents/overview/index.js:885
msgid "Easier collaboration — no need to share passwords with collaborators."
msgstr ""
"Enklere samarbeid – du trenger ikke å dele passord med samarbeidspartnere."

#: document/static/js/modules/documents/overview/index.js:889
msgid "The server can technically access the document contents."
msgstr "Serveren har teknisk tilgang til dokumentinnholdet."

#: document/static/js/modules/documents/overview/index.js:890
msgid "No additional protection beyond your account password."
msgstr "Ingen ekstra beskyttelse utover kontopassordet ditt."

#: document/static/js/modules/documents/overview/index.js:894
msgid "Choose encryption type of new document."
msgstr "Velg krypteringstype for nytt dokument."

#: document/static/js/modules/documents/overview/index.js:899
msgid "Non-encrypted"
msgstr "Ikke-kryptert"

#: document/static/js/modules/documents/overview/index.js:904
msgid "Encrypted"
msgstr "Kryptert"

#: document/static/js/modules/documents/overview/index.js:948
msgid "Set Up Personal Encryption (Optional)"
msgstr "Konfigurer personlig kryptering (valgfritt)"

#: document/static/js/modules/documents/overview/index.js:950
msgid ""
"Would you like to set up a personal passphrase now? This will allow you to "
"unlock all your encrypted documents with a single passphrase."
msgstr ""
"Vil du sette opp en personlig passordfrase nå? Dette lar deg låse opp alle "
"de krypterte dokumentene dine med en enkelt passordfrase."

#: document/static/js/modules/documents/overview/index.js:951
msgid "Note:"
msgstr "Note:"

#: document/static/js/modules/documents/overview/index.js:951
msgid "This is optional. You can also use a per-document password instead."
msgstr ""
