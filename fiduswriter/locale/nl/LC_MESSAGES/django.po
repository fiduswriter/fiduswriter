msgid "Untitled"
msgstr "Zonder titel"

#: document/emails.py:21
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has changed your access rights to %(rights)s on the document '%(document_title)s'. \n"
"Open the document: %(link)s"
msgstr ""
"Hallo %(collaborator_name)s,\n"
"%(owner)s heeft uw toegangsrechten tot %(rights)s op het document '%(document_title)s' gewijzigd. \n"
"Open het document: %(link)s"

#: document/emails.py:32
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has changed your access rights to"
" %(rights)s on the document '%(document_title)s'.</p>"
msgstr ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s heeft je toegangsrechten "
"gewijzigd naar %(rights)s voor het document '%(document_title)s'.</p>"

#: document/emails.py:43
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has shared the document '%(document_title)s' with you and given you %(rights)s access rights. \n"
"Open document: %(link)s"
msgstr ""
"Hallo %(collaborator_name)s,\n"
"%(owner)s heeft het document '%(document_title)s' met u gedeeld en u %(rights)s toegangsrechten gegeven. \n"
"Document openen: %(link)s"

#: document/emails.py:55
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has shared the document "
"'%(document_title)s' with you and given you %(rights)s access rights.</p>"
msgstr ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s heeft het document "
"'%(document_title)s' met je gedeeld en je %(rights)s toegangsrechten "
"gegeven.</p>"

#: document/emails.py:89
msgid "shared"
msgstr "gedeeld"

#: document/emails.py:91 document/emails.py:207 document/emails.py:286
msgid "Document"
msgstr "Document"

#: document/emails.py:93 document/emails.py:209
msgid "Author"
msgstr "Auteur"

#: document/emails.py:95
msgid "Access Rights"
msgstr "Toegangsrechten"

#: document/emails.py:98 document/emails.py:214
msgid "Access the document"
msgstr "Open het document"

#: document/emails.py:101
#, python-format
msgid "Document shared: %(document_title)s"
msgstr "Document gedeeld: %(document_title)s"

#: document/emails.py:123
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(commentator)s has mentioned you in a comment in the document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Go to the document here: %(link)s"
msgstr ""
"Hallo %(collaborator_name)s,\n"
"%(commentator)s heeft je genoemd in een opmerking in het document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Ga hier naar het document: %(link)s"

#: document/emails.py:136
#, python-format
msgid ""
"Hey %(collaborator_name)s,<br>%(commentator)s has mentioned you in a comment"
" in the document '%(document_title)s'."
msgstr ""
"Hallo %(collaborator_name)s,<br>%(commentator)s heeft je genoemd in een "
"opmerking in het document '%(document_title)s'."

#: document/emails.py:143
#, python-format
msgid "Comment on : %(document_title)s"
msgstr "Reageer op: %(document_title)s"

#: document/emails.py:148
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(commentator)s has assigned you to a comment in the document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Go to the document here: %(link)s"
msgstr ""
"Hallo %(collaborator_name)s,\n"
"%(commentator)s heeft u toegewezen aan een opmerking in het document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Ga hier naar het document: %(link)s"

#: document/emails.py:159
#, python-format
msgid ""
"Hey %(collaborator_name)s,<br>%(commentator)s has assigned you to a comment "
"in the document '%(document_title)s'."
msgstr ""
"Hallo %(collaborator_name)s,<br>%(commentator)s heeft je toegewezen aan een "
"opmerking in het document '%(document_title)s'."

#: document/emails.py:166
#, python-format
msgid "Comment assignment on : %(document_title)s"
msgstr "Toewijzing van commentaar op: %(document_title)s"

#: document/emails.py:171
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(commentator)s has assigned you to a "
"comment in the document '%(document)s':</p>%(comment_html)s<p>Go to the "
"document <a href=\"%(link)s\">here</a>.</p>"
msgstr ""
"<p>Hey %(collaborator_name)s,<br>%(commentator)s heeft je toegewezen aan een"
" opmerking in het document '%(document)s':</p>%(comment_html)s<p>Ga <a "
"href=\"%(link)s\">hier</a> naar het document.</p>"

#: document/emails.py:211
msgid "Comment"
msgstr "Opmerking"

#: document/emails.py:239
#, python-format
msgid ""
"Hey %(owner_name)s,\n"
"%(requester_name)s has requested %(rights)s access to the document '%(document_title)s'. \n"
"Open the document to grant access: %(link)s"
msgstr ""
"Hallo %(owner_name)s,\n"
"%(requester_name)s heeft %(rights)s toegang gevraagd tot het document '%(document_title)s'. \n"
"Open het document om toegang te verlenen: %(link)s"

#: document/emails.py:251
#, python-format
msgid ""
"<p>Hey %(owner_name)s,<br>%(requester_name)s has requested %(rights)s access"
" to the document '%(document_title)s'.</p>"
msgstr ""
"<p>Hey %(owner_name)s,<br>%(requester_name)s heeft %(rights)s toegang "
"gevraagd tot het document '%(document_title)s'.</p>"

