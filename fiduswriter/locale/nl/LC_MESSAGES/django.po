#: browser_check/templates/browser_check/browser_not_supported.html:4
#: browser_check/templates/browser_check/browser_not_supported.html:27
msgid "Browser not supported"
msgstr "Browser niet ondersteund"

#: browser_check/templates/browser_check/browser_not_supported.html:28
msgid ""
"\n"
"                Your browser is not supported by Fidus Writer.\n"
"                Please update! We recommend using a current\n"
"                version of Chrome/Chromium or Firefox on a\n"
"                desktop computer.\n"
"            "
msgstr ""
"\n"
"Uw browser wordt niet ondersteund door Fidus Writer.\n"
"                Update alstublieft! Wij raden aan om stroom te gebruiken\n"
"                versie van Chrome/Chromium of Firefox op een\n"
"                desktopcomputer."

