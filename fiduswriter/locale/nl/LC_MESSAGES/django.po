#: user/templates/account/email/email_confirmation_message.html:7
#: user/templates/account/email/password_reset_key_message.html:7
#, python-format
msgid "Hello from %(site_name)s!"
msgstr "Hallo van %(site_name)s!"

#: user/templates/account/email/email_confirmation_message.html:12
#, python-format
msgid ""
"You are receiving this e-mail because user %(user_display)s has given yours "
"as an e-mail address to connect their account."
msgstr ""
"U ontvangt deze e-mail omdat gebruiker %(user_display)s uw e-mailadres heeft"
" opgegeven om zijn/haar account te koppelen."

#: user/templates/account/email/email_confirmation_message.html:16
#, python-format
msgid "To confirm this is correct, go to <a href=\"%(url)s\">%(url)s</a>."
msgstr ""
"Om te bevestigen dat dit juist is, ga naar <a href=\"%(url)s\">%(url)s</a>."

#: user/templates/account/email/email_confirmation_message.html:20
#: user/templates/account/email/password_reset_key_message.html:26
#, python-format
msgid "Thank you from %(site_name)s!"
msgstr "Bedankt namens %(site_name)s!"

#: user/templates/account/email/password_reset_key_message.html:11
msgid ""
"You are receiving this e-mail because you or someone else has requested a "
"password for your user account."
msgstr ""
"U ontvangt deze e-mail omdat u of iemand anders een wachtwoord voor uw "
"gebruikersaccount heeft aangevraagd."

#: user/templates/account/email/password_reset_key_message.html:14
msgid ""
"It can be safely ignored if you did not request a password reset. Click the "
"link below to reset your password."
msgstr ""
"Het kan veilig worden genegeerd als u geen wachtwoordreset heeft "
"aangevraagd. Klik op de onderstaande link om uw wachtwoord opnieuw in te "
"stellen."

#: user/templates/account/email/password_reset_key_message.html:21
#, python-format
msgid "In case you forgot, your username is %(username)s."
msgstr "Mocht u het vergeten zijn: uw gebruikersnaam is %(username)s."

