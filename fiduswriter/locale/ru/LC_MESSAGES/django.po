#: document/emails.py:21
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has changed your access rights to %(rights)s on the document '%(document_title)s'. \n"
"Open the document: %(link)s"
msgstr ""
"Привет, %(collaborator_name)s,\n"
"%(owner)s изменил ваши права доступа на %(rights)s к документу «%(document_title)s». \n"
"Откройте документ: %(link)s"

#: document/emails.py:32
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has changed your access rights to"
" %(rights)s on the document '%(document_title)s'.</p>"
msgstr ""
"<p>Привет, %(collaborator_name)s!<br>%(owner)s изменил ваши права доступа на"
" %(rights)s к документу «%(document_title)s».</p>"

#: document/emails.py:43
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has shared the document '%(document_title)s' with you and given you %(rights)s access rights. \n"
"Open document: %(link)s"
msgstr ""
"Привет, %(collaborator_name)s,\n"
"%(owner)s предоставил вам доступ к документу «%(document_title)s» и предоставил вам права доступа %(rights)s. \n"
"Открыть документ: %(link)s"

#: document/emails.py:55
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has shared the document "
"'%(document_title)s' with you and given you %(rights)s access rights.</p>"
msgstr ""
"<p>Привет, %(collaborator_name)s!<br>%(owner)s предоставил вам доступ к "
"документу «%(document_title)s» и предоставил вам права доступа "
"%(rights)s.</p>"

