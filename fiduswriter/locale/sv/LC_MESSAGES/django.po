msgstr "Ofrälse"

#: document/emails.py:21
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has changed your access rights to %(rights)s on the document '%(document_title)s'. \n"
"Open the document: %(link)s"
msgstr ""
"Hej %(collaborator_name)s,\n"
"%(owner)s har ändrat dina åtkomsträttigheter till %(rights)s på dokumentet '%(document_title)s'. \n"
"Öppna dokumentet: %(link)s"

#: document/emails.py:32
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has changed your access rights to"
" %(rights)s on the document '%(document_title)s'.</p>"
msgstr ""
"<p>Hej %(collaborator_name)s,<br>%(owner)s har ändrat dina "
"åtkomsträttigheter till %(rights)s på dokumentet \"%(document_title)s\".</p>"

#: document/emails.py:43
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(owner)s has shared the document '%(document_title)s' with you and given you %(rights)s access rights. \n"
"Open document: %(link)s"
msgstr ""
"Hej %(collaborator_name)s,\n"
"%(owner)s har delat dokumentet '%(document_title)s' med dig och gett dig %(rights)s åtkomsträttigheter. \n"
"Öppna dokument: %(link)s"

#: document/emails.py:55
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(owner)s has shared the document "
"'%(document_title)s' with you and given you %(rights)s access rights.</p>"
msgstr ""
"<p>Hej %(collaborator_name)s,<br>%(owner)s har delat dokumentet "
"\"%(document_title)s\" med dig och gett dig %(rights)s "
"åtkomsträttigheter.</p>"

#: document/emails.py:89
msgid "shared"
msgstr "delad"

#: document/emails.py:91 document/emails.py:207 document/emails.py:286
msgid "Document"
msgstr "Dokumentera"

#: document/emails.py:93 document/emails.py:209
msgid "Author"
msgstr "Författare"

#: document/emails.py:95
msgid "Access Rights"
msgstr "Åtkomsträttigheter"

#: document/emails.py:98 document/emails.py:214
msgid "Access the document"
msgstr "Öppna dokumentet"

#: document/emails.py:101
#, python-format
msgid "Document shared: %(document_title)s"
msgstr "Dokument delat: %(document_title)s"

#: document/emails.py:123
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(commentator)s has mentioned you in a comment in the document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Go to the document here: %(link)s"
msgstr ""
"Hej %(collaborator_name)s,\n"
"%(commentator)s har nämnt dig i en kommentar i dokumentet \"%(document)s\":\n"
"\n"
"%(comment_text)s\n"
"\n"
"Gå till dokumentet här: %(link)s"

#: document/emails.py:136
#, python-format
msgid ""
"Hey %(collaborator_name)s,<br>%(commentator)s has mentioned you in a comment"
" in the document '%(document_title)s'."
msgstr ""
"Hej %(collaborator_name)s,<br>%(commentator)s har nämnt dig i en kommentar i"
" dokumentet \"%(document_title)s\"."

#: document/emails.py:143
#, python-format
msgid "Comment on : %(document_title)s"
msgstr "Kommentar till : %(document_title)s"

#: document/emails.py:148
#, python-format
msgid ""
"Hey %(collaborator_name)s,\n"
"%(commentator)s has assigned you to a comment in the document '%(document)s':\n"
"\n"
"%(comment_text)s\n"
"\n"
"Go to the document here: %(link)s"
msgstr ""
"Hej %(collaborator_name)s,\n"
"%(commentator)s har tilldelat dig en kommentar i dokumentet \"%(document)s\":\n"
"\n"
"%(comment_text)s\n"
"\n"
"Gå till dokumentet här: %(link)s"

#: document/emails.py:159
#, python-format
msgid ""
"Hey %(collaborator_name)s,<br>%(commentator)s has assigned you to a comment "
"in the document '%(document_title)s'."
msgstr ""
"Hej %(collaborator_name)s,<br>%(commentator)s har tilldelat dig en kommentar"
" i dokumentet \"%(document_title)s\"."

#: document/emails.py:166
#, python-format
msgid "Comment assignment on : %(document_title)s"
msgstr "Kommentarsuppgift på: %(document_title)s"

#: document/emails.py:171
#, python-format
msgid ""
"<p>Hey %(collaborator_name)s,<br>%(commentator)s has assigned you to a "
"comment in the document '%(document)s':</p>%(comment_html)s<p>Go to the "
"document <a href=\"%(link)s\">here</a>.</p>"
msgstr ""
"<p>Hej %(collaborator_name)s,<br>%(commentator)s har tilldelat dig en "
"kommentar i dokumentet \"%(document)s\":</p>%(comment_html)s<p>Gå till "
"dokumentet <a href=\"%(link)s\">här</a>.</p>"

#: document/emails.py:211
msgid "Comment"
msgstr "Kommentar"

#: document/emails.py:239
#, python-format
msgid ""
"Hey %(owner_name)s,\n"
"%(requester_name)s has requested %(rights)s access to the document '%(document_title)s'. \n"
"Open the document to grant access: %(link)s"
msgstr ""
"Hej %(owner_name)s,\n"
"%(requester_name)s har begärt %(rights)s tillgång till dokumentet '%(document_title)s'. \n"
"Öppna dokumentet för att ge åtkomst: %(link)s"

#: document/emails.py:251
#, python-format
msgid ""
"<p>Hey %(owner_name)s,<br>%(requester_name)s has requested %(rights)s access"
" to the document '%(document_title)s'.</p>"
msgstr ""
"<p>Hej %(owner_name)s,<br>%(requester_name)s har begärt %(rights)s åtkomst "
"till dokumentet \"%(document_title)s\".</p>"

#: document/emails.py:284
